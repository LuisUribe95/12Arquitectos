# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php83” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# --- REDIRECCIÓN UNIFICADA: FUERZA HTTPS Y ELIMINA WWW ---
RewriteEngine On

# 1. Si entran con HTTP, fuerza HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://12arquitectos.com.mx/$1 [R=301,L]

# 2. Si entran con WWW, elimina las WWW y mantiene HTTPS
RewriteCond %{HTTP_HOST} ^www\.12arquitectos\.com\.mx [NC]
RewriteRule ^(.*)$ https://12arquitectos.com.mx/$1 [R=301,L]


# --- MEJORA DE PERFORMANCE (CACHÉ) ---
<IfModule mod_expires.c>
    ExpiresActive On

    # Imágenes (1 año) - Cubre tus archivos .webp de la fachada y galería
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Páginas HTML (1 día o unas horas para evitar retraso en el servidor)
    ExpiresByType text/html "access plus 1 day"
    
    # Archivos de estilo y scripts (1 mes) - Para bootstrap y owl.carousel
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # Fuentes (1 año) - Ayuda con el error de "Font Display"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Habilitar compresión Gzip (Opcional pero muy recomendado)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript
</IfModule>